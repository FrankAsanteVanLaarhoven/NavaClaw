# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=my_crawler
DB_USER=postgres
DB_PASSWORD=postgres
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_MAX_CONNECTIONS=20

# Crawler Configuration
CRAWLER_MAX_WORKERS=4
CRAWLER_MAX_CONCURRENT_TASKS=10
CRAWLER_TASK_TIMEOUT=300
CRAWLER_RETRY_ATTEMPTS=3
CRAWLER_RETRY_DELAY=5
CRAWLER_DEFAULT_DELAY=1.0
CRAWLER_USER_AGENT=My-Crawler/1.0

# Application Configuration
DEBUG=false
LOG_LEVEL=INFO 